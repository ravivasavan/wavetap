{
  "$description": "WaveTap primitive design tokens (W3C DTCG). Raw values from 09_DESIGN_SYSTEM.md — the single source of truth. Semantic aliases live in semantic.json; both compile into packages/tokens via build.mjs. Edit here, then run `pnpm --filter @wavetap/tokens build`.",
  "color": {
    "$type": "color",
    "white": { "$value": "#FFFFFF" },
    "neutral": {
      "50": { "$value": "#FAFAF8", "$description": "Page background" },
      "100": { "$value": "#F5F4F0", "$description": "Card background, secondary surfaces" },
      "200": { "$value": "#E8E6E0", "$description": "Borders, dividers" },
      "300": { "$value": "#D1CEC5", "$description": "Disabled states, placeholder text" },
      "400": { "$value": "#A8A49A", "$description": "Secondary text" },
      "500": { "$value": "#7A756B", "$description": "Body text (secondary)" },
      "600": { "$value": "#5C5850", "$description": "Body text (primary)" },
      "700": { "$value": "#3D3A34", "$description": "Headings" },
      "800": { "$value": "#2A2824", "$description": "High emphasis text" },
      "900": { "$value": "#1A1916", "$description": "Maximum contrast" }
    },
    "accent": {
      "50": { "$value": "#FFF5F2", "$description": "Accent background (light)" },
      "100": { "$value": "#FFE8E0", "$description": "Hover states, highlights" },
      "200": { "$value": "#FFD0C0", "$description": "Active states" },
      "300": { "$value": "#FFB09A", "$description": "Badges, indicators" },
      "400": { "$value": "#FF8B6A", "$description": "Secondary buttons" },
      "500": { "$value": "#E8694A", "$description": "Primary accent — CTAs, links, active states" },
      "600": { "$value": "#C9523A", "$description": "Hover on primary accent" },
      "700": { "$value": "#A13D2C", "$description": "Pressed states" }
    },
    "success": { "$value": "#4A9A6B", "$description": "Confirmed, success states" },
    "warning": { "$value": "#D4953A", "$description": "Pending, attention needed" },
    "error": { "$value": "#C94A4A", "$description": "Error, destructive actions" },
    "info": { "$value": "#4A7AC9", "$description": "Informational" }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "8px", "$description": "Inputs, small elements" },
    "md": { "$value": "12px", "$description": "Cards, buttons" },
    "lg": { "$value": "16px", "$description": "Modals, large panels" },
    "full": { "$value": "9999px", "$description": "Avatars, pills, badges" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px rgba(26, 25, 22, 0.06)", "$description": "Subtle lift" },
    "md": { "$value": "0 4px 12px rgba(26, 25, 22, 0.08)", "$description": "Cards, floating elements" },
    "lg": { "$value": "0 8px 24px rgba(26, 25, 22, 0.12)", "$description": "Modals, elevated panels" },
    "xl": { "$value": "0 16px 48px rgba(26, 25, 22, 0.16)", "$description": "Dialogs, popovers" }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "sans": { "$value": "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" }
  },
  "fontSize": {
    "$type": "dimension",
    "heading-xl": { "$value": "32px", "$description": "Page titles" },
    "heading-lg": { "$value": "24px", "$description": "Section headings" },
    "heading-md": { "$value": "20px", "$description": "Card titles" },
    "body-lg": { "$value": "18px", "$description": "Lead text, important body" },
    "body": { "$value": "16px", "$description": "Default body text" },
    "body-sm": { "$value": "14px", "$description": "Secondary text, captions" },
    "label": { "$value": "14px", "$description": "Form labels, tags" },
    "button": { "$value": "16px", "$description": "Button text" }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 }
  },
  "lineHeight": {
    "$type": "number",
    "heading": { "$value": 1.3 },
    "body": { "$value": 1.5 }
  }
}
