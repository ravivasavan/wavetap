# ──────────────────────────────────────────────────────────────────────────
# WaveTap — environment template
#
# Copy the relevant block into the REAL (git-ignored) files and fill in values:
#   apps/web/.env.local     ← web (Next.js)        — NEXT_PUBLIC_* + server-only
#   apps/mobile/.env        ← native (Expo)         — EXPO_PUBLIC_* only
#   CI/CD secrets store     ← Vercel + EAS          — server-only + HEROUI_AUTH_TOKEN
#
# .env and .env.local are git-ignored (see .gitignore). NEVER commit real values.
# Only THIS file (.env.example, placeholders) is committed.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase — public (safe in client bundles) ─────────────────────────────
# *_ANON_KEY holds the new **Publishable key** (sb_publishable_...). Safe to
# expose ONLY because RLS is enabled on every table. From Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Supabase — server-only (Edge Functions / route handlers) ───────────────
# Holds the new **Secret key** (sb_secret_...). Privileged — NEVER ship in the
# mobile bundle or any client, and NEVER give it a NEXT_PUBLIC_/EXPO_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://wavetap.app
EXPO_PUBLIC_APP_URL=https://wavetap.app

# ── Resend (email) — server-only ───────────────────────────────────────────
RESEND_API_KEY=your-resend-key

# ── HeroUI Pro ───────────────────────────────────────────────────────────────
# PERSONAL token — local dev + the HeroUI MCP. Tied to YOUR account. Do NOT use in CI.
#   Get it from https://heroui.pro/dashboard
HEROUI_PERSONAL_TOKEN=your-personal-token
# CI/CD token — Vercel + EAS builds fetch Pro artifacts via the postinstall step.
#   Scoped to the license, rotatable independently. Use THIS in pipelines, not the personal token.
HEROUI_AUTH_TOKEN=your-cicd-token
